enum StockMovementType {
  RECEIPT
  SHIPMENT
  ADJUSTMENT
  TRANSFER
}

enum StockReservationStatus {
  ACTIVE
  RELEASED
}

model Warehouse {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  address     String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stockLevels       StockLevel[]
  stockMovements      StockMovement[] @relation("MovementWarehouse")
  incomingTransfers   StockMovement[] @relation("MovementTargetWarehouse")
  stockReservations   StockReservation[]

  @@index([isActive, sortOrder])
}

model StockLevel {
  id                String   @id @default(uuid())
  warehouseId       String
  variantId         String
  quantityOnHand    Int      @default(0)
  quantityReserved  Int      @default(0)
  lowStockThreshold Int?
  updatedAt         DateTime @updatedAt

  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, variantId])
  @@index([variantId])
}

model StockMovement {
  id                String            @id @default(uuid())
  warehouseId       String
  variantId         String
  type              StockMovementType
  quantityChange    Int
  quantityBefore    Int
  quantityAfter     Int
  note              String?
  performedById     String?
  targetWarehouseId String?
  createdAt         DateTime          @default(now())

  warehouse       Warehouse      @relation("MovementWarehouse", fields: [warehouseId], references: [id], onDelete: Restrict)
  targetWarehouse Warehouse?     @relation("MovementTargetWarehouse", fields: [targetWarehouseId], references: [id], onDelete: SetNull)
  variant         ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  performedBy     User?          @relation(fields: [performedById], references: [id], onDelete: SetNull)

  @@index([warehouseId, createdAt])
  @@index([variantId, createdAt])
}

model StockReservation {
  id            String                 @id @default(uuid())
  warehouseId   String
  variantId     String
  quantity      Int
  reference     String?
  note          String?
  status        StockReservationStatus @default(ACTIVE)
  performedById String?
  createdAt     DateTime               @default(now())
  releasedAt    DateTime?

  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  performedBy User?          @relation(fields: [performedById], references: [id], onDelete: SetNull)

  @@index([warehouseId, status])
  @@index([variantId, status])
}
