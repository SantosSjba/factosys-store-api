# =============================================================================
# FACTOSYS STORE API — producción (EasyPanel / AWS)
# Copiar a .env.production y rellenar valores reales
# =============================================================================

NODE_ENV=production

APP_NAME=FACTOSYS STORE API
APP_PORT=3000
APP_URL=https://api.tudominio.com
API_PREFIX=api
DEV_HTTPS=false
SWAGGER_ENABLED=false
LOG_LEVEL=info

DATABASE_URL=postgresql://user:pass@host:5432/factosys_store_db?sslmode=require

JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d

# Redis interno EasyPanel (misma red que la API)
REDIS_HOST=factosys_factosys_store_redis
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=
REDIS_URL=redis://default:PASSWORD@factosys_factosys_store_redis:6379

QUEUE_PREFIX=factosys
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_REMOVE_ON_COMPLETE=500
QUEUE_REMOVE_ON_FAIL=500

ELASTICSEARCH_NODE=http://factosys_elasticsearch:9200

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=factosys-store
AWS_S3_ENDPOINT=
AWS_S3_PUBLIC_URL=
AWS_S3_FORCE_PATH_STYLE=true

MAIL_HOST=mail.factosysperu.com
MAIL_PORT=465
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@factosysperu.com
MAIL_SECURE=true

FRONTEND_URL=https://tienda.tudominio.com
ADMIN_FRONTEND_URL=https://tienda.tudominio.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.tudominio.com/api/store/auth/google/callback
