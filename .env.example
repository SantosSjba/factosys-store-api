# =============================================================================
# FACTOSYS STORE API — plantilla de variables de entorno
# Arquitectura: NestJS + PostgreSQL + Redis + Elasticsearch + S3 + BullMQ
# =============================================================================

NODE_ENV=development

# --- App / API Gateway ---
APP_NAME=FACTOSYS STORE API
APP_PORT=3000
APP_URL=http://localhost:3000
API_PREFIX=api
DEV_HTTPS=false
SWAGGER_ENABLED=true
LOG_LEVEL=debug

# --- PostgreSQL ---
DATABASE_URL=postgresql://factosys:factosys@localhost:5432/factosys_store

# --- JWT ---
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_min_32_chars
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d

# --- Redis (caché, sesiones, carritos) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_URL=

# --- BullMQ ---
QUEUE_PREFIX=factosys
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_REMOVE_ON_COMPLETE=500
QUEUE_REMOVE_ON_FAIL=500

# --- Elasticsearch (búsqueda avanzada) ---
ELASTICSEARCH_NODE=http://localhost:9200

# --- S3 / MinIO (archivos e imágenes) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=factosys-store
AWS_S3_ENDPOINT=
# URL directa MinIO (solo si el bucket es público). Buckets privados usan /api/media/...
AWS_S3_PUBLIC_URL=
# Base absoluta opcional para imágenes (producción sin proxy /api). Vacío = ruta relativa /api/media/...
AWS_S3_READABLE_URL_BASE=
AWS_S3_FORCE_PATH_STYLE=true

# --- Email (SMTP o SendGrid) ---
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@factosys.store
MAIL_SECURE=false
# SENDGRID_API_KEY=

# --- SMS (Twilio — fase futura) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=

# --- Frontend Nuxt 4 ---
FRONTEND_URL=http://localhost:3001
ADMIN_FRONTEND_URL=http://localhost:3001

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://127.0.0.1:3000/api/store/auth/google/callback

# --- Pagos — Mercado Pago (Checkout API / Orders) ---
# --- Mercado Pago (Checkout API vía Orders) ---
# Docs: https://www.mercadopago.com.pe/developers/es/docs/checkout-api-orders/overview
MERCADOPAGO_ENABLED=false
MERCADOPAGO_TEST_MODE=true
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_APP_ID=
MERCADOPAGO_USER_ID=
MERCADOPAGO_WEBHOOK_SECRET=
# Webhook URL en Tus integraciones: {APP_URL}/api/webhooks/payments/MERCADO_PAGO
# Eventos recomendados: Orders y Payments

# --- Pagos (otros — fase futura) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# --- Seed ---
SEED_SUPER_EMAIL=super@factosys.store
SEED_SUPER_PASSWORD=Super123!
SEED_ADMIN_EMAIL=admin@factosys.store
SEED_ADMIN_PASSWORD=Admin123!
SEED_CUSTOMER_EMAIL=cliente@factosys.store
SEED_CUSTOMER_PASSWORD=Cliente123!

# --- Timeouts (ms) — ajustar si la BD remota es lenta ---
HTTP_REQUEST_TIMEOUT_MS=120000
HTTP_SLOW_REQUEST_MS=3000
DB_CONNECTION_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=60000
DB_POOL_MAX=10
DB_TRANSACTION_TIMEOUT_MS=60000
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_COMMAND_TIMEOUT_MS=10000
MAIL_CONNECTION_TIMEOUT_MS=10000
S3_REQUEST_TIMEOUT_MS=30000
