NODE_ENV=development

APP_NAME=FACTOSYS STORE API
APP_PORT=3000
APP_URL=http://localhost:3000
API_PREFIX=api

DATABASE_URL=postgresql://factosys:factosys@localhost:5432/factosys_store

JWT_SECRET=change_me_jwt_secret
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

ELASTICSEARCH_NODE=http://localhost:9200

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@factosys.store
MAIL_SECURE=false

# Tienda Nuxt (factosys-store-web) — puerto 3001
FRONTEND_URL=http://localhost:3001
# Panel admin (futuro) — puerto distinto
ADMIN_FRONTEND_URL=http://localhost:3002

# Google OAuth (opcional — sin esto, /store/auth/google queda deshabilitado)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/store/auth/google/callback

SWAGGER_ENABLED=true
# Safari suele abrir https://localhost sin certificado → error TLS en Swagger.
# Solución: pnpm certs:dev y DEV_HTTPS=true (usa https://127.0.0.1:3000/docs)
# Alternativa sin HTTPS: abre http://127.0.0.1:3000/docs (no uses https://)
DEV_HTTPS=false
LOG_LEVEL=debug

# Usuario con TODOS los roles (dev / QA)
SEED_SUPER_EMAIL=super@factosys.store
SEED_SUPER_PASSWORD=Super123!
# Usuario admin estándar (solo rol admin = todos los permisos)
SEED_ADMIN_EMAIL=admin@factosys.store
SEED_ADMIN_PASSWORD=Admin123!
